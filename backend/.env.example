# Server
PORT=5000
NODE_ENV=production

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=chargebyte_user
DB_PASSWORD=your_secure_password_here
DB_NAME=chargebyte_db

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://your-frontend-domain.lovable.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# M-Pesa (Safaricom Daraja)
MPESA_ENVIRONMENT=production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=
# Public base URL Safaricom can reach for callbacks (no trailing slash)
MPESA_CALLBACK_BASE_URL=https://your-backend-domain.com
